{
  "name": "@domainstack/email",
  "version": "0.0.0-beta.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./templates/*": "./src/templates/*.tsx",
    "./components/*": "./src/components/*.tsx"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
